{
  "name": "@animakit/complexity-scorer",
  "version": "0.1.0",
  "description": "Classify LLM tasks in <1ms with zero tokens - 5 weighted signals to complexity tier, before you ever call an LLM.",
  "license": "MIT",
  "author": "Justine Serna Aza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/animakit-ai/anima.git",
    "directory": "packages/complexity-scorer"
  },
  "keywords": [
    "llm",
    "agents",
    "routing",
    "complexity",
    "model-routing",
    "cost-optimization"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "bench": "node --import tsx benchmarks/latency.ts"
  },
  "publishConfig": {
    "access": "public"
  }
}
